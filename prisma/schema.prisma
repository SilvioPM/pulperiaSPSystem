generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Categoria {
  id        Int       @id @default(autoincrement())
  nombre    String
  productos Producto[]
  creadoEn  DateTime  @default(now())
}

model Producto {
  id                Int              @id @default(autoincrement())
  nombre            String
  codigo            String?          @unique
  precio            Float
  costo             Float            @default(0)
  stock             Float            @default(0)
  stockMinimo       Float            @default(5)
  unidad            String           @default("unidad")
  unidadBase        String           @default("unidad")
  unidadCompra      String           @default("unidad")
  factorConversion  Float            @default(1)
  precioMayor       Float            @default(0)
  unidadVenta2      String?
  precioVenta2      Float            @default(0)
  factorVenta2      Float            @default(1)
  categoriaId       Int
  categoria         Categoria        @relation(fields: [categoriaId], references: [id])
  activo            Boolean          @default(true)
  creadoEn          DateTime         @default(now())
  detalles          DetalleFac[]
  movimientos       MovInventario[]
  detallesCompra    DetalleCompra[]
  detallesProforma  DetalleProforma[]

  @@index([nombre])
  @@index([categoriaId])
  @@index([activo])
}

model Cliente {
  id            Int        @id @default(autoincrement())
  nombre        String
  telefono      String?
  cedula        String?
  direccion     String?
  limiteCredito Float      @default(0)
  facturas      Factura[]
  proformas     Proforma[]
  creadoEn      DateTime   @default(now())

  @@index([nombre])
}

model Factura {
  id               Int        @id @default(autoincrement())
  numero           String     @unique
  clienteId        Int?
  cliente          Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  subtotal         Float
  descuento        Float      @default(0)
  iva              Float      @default(0)
  total            Float
  pagoCon          Float      @default(0)
  cambio           Float      @default(0)
  metodoPago       String     @default("efectivo")
  esCredito        Boolean    @default(false)
  saldoPendiente   Float      @default(0)
  estado           String     @default("pagada")
  anuladaEn        DateTime?
  anuladaPor       String?
  detallesPago     String?
  detalles         DetalleFac[]
  abonos           Abono[]
  creadoEn         DateTime   @default(now())

  @@index([creadoEn])
  @@index([clienteId])
  @@index([estado])
}

model DetalleFac {
  id         Int      @id @default(autoincrement())
  facturaId  Int
  factura    Factura  @relation(fields: [facturaId], references: [id])
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Float
  unidadVenta String?
  precio     Float
  costo      Float    @default(0)
  subtotal   Float
  factorConversion Float @default(1)

  @@index([facturaId])
  @@index([productoId])
}

model MovInventario {
  id               Int      @id @default(autoincrement())
  productoId       Int
  producto         Producto @relation(fields: [productoId], references: [id])
  tipo             String
  cantidad         Float
  cantidadOriginal Float?
  unidadOriginal   String?
  motivo           String?
  creadoEn         DateTime @default(now())

  @@index([productoId])
  @@index([creadoEn])
}

model Abono {
  id        Int      @id @default(autoincrement())
  facturaId Int
  factura   Factura  @relation(fields: [facturaId], references: [id], onDelete: Restrict)
  monto     Float
  nota      String?
  creadoEn  DateTime @default(now())
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String?
  contacto  String?
  direccion String?
  email     String?
  activo    Boolean  @default(true)
  compras   Compra[]
  creadoEn  DateTime @default(now())
}

model Compra {
  id               Int            @id @default(autoincrement())
  numero           String         @unique
  proveedorId      Int
  proveedor        Proveedor      @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  subtotal         Float
  iva              Float          @default(0)
  total            Float
  esCredito        Boolean        @default(false)
  saldoPendiente   Float          @default(0)
  estado           String         @default("pagada")
  nota             String?
  detalles         DetalleCompra[]
  abonos           AbonoCompra[]
  creadoEn         DateTime       @default(now())
}

model DetalleCompra {
  id        Int      @id @default(autoincrement())
  compraId  Int
  compra    Compra   @relation(fields: [compraId], references: [id], onDelete: Restrict)
  productoId Int
  producto  Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  cantidad  Float
  unidad    String   @default("unidad")
  costo     Float
  subtotal  Float
}

model AbonoCompra {
  id        Int      @id @default(autoincrement())
  compraId  Int
  compra    Compra   @relation(fields: [compraId], references: [id], onDelete: Restrict)
  monto     Float
  nota      String?
  creadoEn  DateTime @default(now())
}

model Proforma {
  id                Int               @id @default(autoincrement())
  numero            String            @unique
  clienteId         Int?
  cliente           Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  subtotal          Float
  iva               Float             @default(0)
  total             Float
  estado            String            @default("pendiente")
  nota              String?
  validoHasta       DateTime?
  detalles          DetalleProforma[]
  creadoEn          DateTime          @default(now())
}

model DetalleProforma {
  id         Int       @id @default(autoincrement())
  proformaId Int
  proforma   Proforma  @relation(fields: [proformaId], references: [id], onDelete: Restrict)
  productoId Int
  producto   Producto  @relation(fields: [productoId], references: [id], onDelete: Restrict)
  cantidad   Float
  precio     Float
  subtotal   Float
}

model CartSession {
  id        Int      @id @default(autoincrement())
  nombre    String
  data      String
  creadoEn  DateTime @default(now())
}

model Config {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

model Usuario {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  password        String
  nombre          String
  esAdmin         Boolean   @default(false)
  rol             String    @default("cajero")
  modulos         String    @default("[]")
  activo          Boolean   @default(true)
  intentosFallidos Int      @default(0)
  bloqueadoHasta  DateTime?
  creadoEn        DateTime  @default(now())
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuario   String
  accion    String
  entidad   String
  detalle   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entidad])
  @@index([usuario])
}

model Caja {
  id             Int       @id @default(autoincrement())
  usuarioApertura String
  usuarioCierre  String?
  montoInicial   Float     @default(0)
  ventasEfectivoCs Float   @default(0)
  ventasEfectivoUs Float   @default(0)
  ventasTarjeta   Float    @default(0)
  ventasTransfer  Float    @default(0)
  ventasCredito   Float    @default(0)
  totalVendido    Float    @default(0)
  ingresosExtra   Float    @default(0)
  egresos         Float    @default(0)
  efectivoRealCs  Float?
  efectivoRealUs  Float?
  diferencia      Float?
  diferenciaUs    Float?
  observacion     String?
  estado          String   @default("abierta")
  abiertaEn       DateTime @default(now())
  cerradaEn       DateTime?
  arqueo          ArqueoDetalle[]
  movimientos     MovimientoCaja[]

  @@index([estado])
}

model ArqueoDetalle {
  id           Int    @id @default(autoincrement())
  cajaId       Int
  caja         Caja   @relation(fields: [cajaId], references: [id])
  moneda       String // 'C$' o '$'
  denominacion Float
  cantidad     Int
  subtotal     Float
}

model MovimientoCaja {
  id       Int      @id @default(autoincrement())
  cajaId   Int
  caja     Caja     @relation(fields: [cajaId], references: [id])
  tipo     String   // 'entrada' o 'salida'
  concepto String
  moneda   String   // 'C$' o '$'
  monto    Float
  creadoEn DateTime @default(now())
}